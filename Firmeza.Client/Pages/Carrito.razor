@page "/carrito"
@using Firmeza.Client.Models
@using Firmeza.Client.Services
@inject VentaService VentaService
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">🛒 Carrito de Compras</h4>
        <a href="/productos" class="btn btn-outline-secondary">← Volver</a>
    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert alert-success">@Mensaje</div>
    }
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger">@Error</div>
    }

    @if (!ListaCarrito.Any())
    {
        <div class="alert alert-info">Tu carrito está vacío.</div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <table class="table mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Producto</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ListaCarrito)
                    {
                        <tr>
                            <td>@item.Producto.Nombre</td>
                            <td>$@item.Producto.Precio.ToString("N2")</td>
                            <td>
                                <input type="number" min="1" class="form-control form-control-sm"
                                       style="width:80px"
                                       value="@item.Cantidad"
                                       @onchange="e => item.Cantidad = int.Parse(e.Value!.ToString()!)" />
                            </td>
                            <td>$@item.Subtotal.ToString("N2")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Eliminar(item)">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card shadow-sm border-0 p-4" style="max-width:350px;margin-left:auto">
            @{ var subtotal = ListaCarrito.Sum(i => i.Subtotal);
               var iva = subtotal * 0.19m;
               var total = subtotal + iva; }
            <p class="d-flex justify-content-between"><span>Subtotal:</span><strong>$@subtotal.ToString("N2")</strong></p>
            <p class="d-flex justify-content-between"><span>IVA (19%):</span><strong>$@iva.ToString("N2")</strong></p>
            <hr />
            <p class="d-flex justify-content-between fs-5"><span>Total:</span><strong>$@total.ToString("N2")</strong></p>
            <button class="btn btn-dark w-100" @onclick="Comprar" disabled="@Cargando">
                @if (Cargando) { <span>Procesando...</span> } else { <span>Confirmar compra</span> }
            </button>
        </div>
    }
</div>

@code {
    List<CarritoItem> ListaCarrito = new();
    string Mensaje = string.Empty;
    string Error = string.Empty;
    bool Cargando = false;
    int ClienteId = 1;

    protected override async Task OnInitializedAsync()
    {
        var autenticado = await AuthService.IsAuthenticatedAsync();
        if (!autenticado) { Nav.NavigateTo("/login"); return; }
        ListaCarrito = CarritoEstado.Items;

        var clienteIdGuardado = await AuthService.GetClienteIdAsync();
        if (clienteIdGuardado > 0) ClienteId = clienteIdGuardado;
    }

    void Eliminar(CarritoItem item)
    {
        ListaCarrito.Remove(item);
        CarritoEstado.Items = ListaCarrito;
    }

    async Task Comprar()
    {
        Cargando = true;
        Error = string.Empty;
        try
        {
            var request = new CrearVentaRequest
            {
                ClienteId = ClienteId,
                Detalles = ListaCarrito.Select(i => new DetalleVentaRequest
                {
                    ProductoId = i.Producto.Id,
                    Cantidad = i.Cantidad
                }).ToList()
            };

            var venta = await VentaService.CrearVentaAsync(request);
            if (venta != null)
            {
                Mensaje = $"✅ Compra realizada. Venta #{venta.Id}. Revisa tu correo.";
                CarritoEstado.Items = new();
                ListaCarrito = new();
            }
            else
            {
                Error = "Error al procesar la compra.";
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        Cargando = false;
    }
}
