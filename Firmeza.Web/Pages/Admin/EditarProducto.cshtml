@page "{id:int}"
@model Firmeza.Web.Pages.Admin.EditarProductoModel
@{
    ViewData["Title"] = "Editar Producto";
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 p-4" style="max-width:600px;">
    <h5 class="fw-bold mb-4">Editar Producto</h5>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Precio</label>
            <input asp-for="Precio" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Stock</label>
            <input asp-for="Stock" class="form-control" type="number" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-dark">Actualizar</button>
        <a href="/Admin/Productos" class="btn btn-outline-secondary ms-2">Cancelar</a>
    </form>
</div>
