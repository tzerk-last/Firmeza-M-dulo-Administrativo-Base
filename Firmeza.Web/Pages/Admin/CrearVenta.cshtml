@page
@model Firmeza.Web.Pages.Admin.CrearVentaModel
@{
    ViewData["Title"] = "Nueva Venta";
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 p-4" style="max-width:700px;">
    <h5 class="fw-bold mb-4">Nueva Venta</h5>
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Cliente</label>
            <select asp-for="ClienteId" asp-items="Model.ClientesSelect" class="form-select">
                <option value="">-- Selecciona un cliente --</option>
            </select>
            <span asp-validation-for="ClienteId" class="text-danger"></span>
        </div>
        <hr />
        <h6 class="fw-bold">Productos</h6>
        <div id="items">
            <div class="row g-2 mb-2">
                <div class="col-5">
                    <select name="ProductoIds" class="form-select">
                        <option value="">-- Producto --</option>
                        @foreach (var p in Model.ProductosSelect)
                        {
                            <option value="@p.Value">@p.Text</option>
                        }
                    </select>
                </div>
                <div class="col-3">
                    <input type="number" name="Cantidades" class="form-control" placeholder="Cantidad" min="1" value="1" />
                </div>
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="agregarFila()">+ Agregar producto</button>
        <br />
        <button type="submit" class="btn btn-dark">Guardar Venta</button>
        <a href="/Admin/Ventas" class="btn btn-outline-secondary ms-2">Cancelar</a>
    </form>
</div>

<script>
function agregarFila() {
    const div = document.createElement('div');
    div.className = 'row g-2 mb-2';
    div.innerHTML = `
        <div class="col-5">
            <select name="ProductoIds" class="form-select">
                <option value="">-- Producto --</option>
                @foreach (var p in Model.ProductosSelect)
                {
                    <option value="@p.Value">@p.Text</option>
                }
            </select>
        </div>
        <div class="col-3">
            <input type="number" name="Cantidades" class="form-control" placeholder="Cantidad" min="1" value="1" />
        </div>`;
    document.getElementById('items').appendChild(div);
}
</script>
