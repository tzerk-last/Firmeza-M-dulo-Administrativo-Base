@page
@model Firmeza.Web.Pages.Admin.CrearClienteModel
@{
    ViewData["Title"] = "Crear Cliente";
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 p-4" style="max-width:600px;">
    <h5 class="fw-bold mb-4">Nuevo Cliente</h5>
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Documento</label>
            <input asp-for="Documento" class="form-control" />
            <span asp-validation-for="Documento" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Correo</label>
            <input asp-for="Correo" class="form-control" type="email" />
            <span asp-validation-for="Correo" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input asp-for="Telefono" class="form-control" />
            <span asp-validation-for="Telefono" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-dark">Guardar</button>
        <a href="/Admin/Clientes" class="btn btn-outline-secondary ms-2">Cancelar</a>
    </form>
</div>
