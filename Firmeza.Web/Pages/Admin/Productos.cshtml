@page
@model Firmeza.Web.Pages.Admin.ProductosModel
@{
    ViewData["Title"] = "Productos";
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">Lista de Productos</h4>
    <a href="/Admin/CrearProducto" class="btn btn-dark">+ Nuevo Producto</a>
</div>

<div class="mb-3">
    <form method="get">
        <input type="text" name="buscar" value="@Model.Buscar"
               class="form-control" placeholder="Buscar por nombre..." style="max-width:300px;" />
    </form>
</div>

@if (!Model.Productos.Any())
{
    <div class="alert alert-info">No hay productos registrados.</div>
}
else
{
    <div class="card shadow-sm border-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Productos)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Nombre</td>
                        <td>@p.Descripcion</td>
                        <td>$@p.Precio.ToString("N2")</td>
                        <td>@p.Stock</td>
                        <td>
                            <a href="/Admin/EditarProducto/@p.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            <form method="post" asp-page-handler="Eliminar" asp-route-id="@p.Id" style="display:inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('¿Eliminar este producto?')">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
