@page
@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso Denegado – Firmeza</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }
        .card { max-width: 480px; margin: 120px auto; border-radius: 12px; }
    </style>
</head>
<body>
    <div class="card shadow p-5 text-center">
        <div style="font-size:4rem;">🚫</div>
        <h3 class="fw-bold mt-3 text-danger">Acceso Denegado</h3>
        <p class="text-muted mt-2">No tienes permisos para acceder al panel administrativo.</p>
        <p class="text-muted">Solo los <strong>administradores</strong> pueden ingresar aquí.</p>
        <a href="/Login" class="btn btn-dark mt-3">Volver al Login</a>
    </div>
